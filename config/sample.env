# Region
AWS_REGION=eu-west-2

# S3
S3_BUCKET=energy-market-lake-<your-unique-suffix>

# Elexon (no key required)
ELEXON_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1
BACKFILL_DAYS=30
HTTP_TIMEOUT_SECONDS=30

# ENTSO-E (requires token)
ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api
ENTSOE_TOKEN=replace_me
ENTSOE_ZONES=GB,FR,DE,NL

# ENTSOG (public API)
ENTSOG_BASE_URL=https://transparency.entsog.eu/api/v1
ENTSOG_POINT_DIRECTIONS=
ENTSOG_FLOW_INDICATOR=Physical Flow
ENTSOG_DEMAND_INDICATOR=Allocation
ENTSOG_PERIOD_TYPE=day
ENTSOG_TIMEZONE=WET
ENTSOG_LIMIT=1000
